# Development Environment Configuration
# CaloMeal MVP - Development Settings

# Database Configuration
DATABASE_URL=postgres://postgres:password@localhost:5432/calomeal?sslmode=disable
DB_HOST=localhost
DB_PORT=5432
DB_NAME=calomeal
DB_USER=postgres
DB_PASSWORD=password

# Service Addresses (Development)
FOOD_SERVICE_ADDR=localhost:50051
LOGS_SERVICE_ADDR=localhost:50052
ANALYTICS_SERVICE_ADDR=localhost:50053

# BFF Configuration
BFF_PORT=8080
BFF_HOST=localhost

# Frontend Configuration
FRONTEND_PORT=5173
FRONTEND_HOST=localhost

# Security Configuration
JWT_SECRET=dev_jwt_secret_key
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging Configuration
LOG_LEVEL=debug
LOG_FORMAT=text

# Performance Configuration
MAX_CONNECTIONS=10
CONNECTION_TIMEOUT=10s
REQUEST_TIMEOUT=30s

# Health Check Configuration
HEALTH_CHECK_INTERVAL=10s
HEALTH_CHECK_TIMEOUT=5s

# Monitoring Configuration
METRICS_ENABLED=false
METRICS_PORT=9090

# Error Handling Configuration
RETRY_MAX_ATTEMPTS=3
RETRY_INITIAL_DELAY=100ms
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RESET_TIMEOUT=10s
